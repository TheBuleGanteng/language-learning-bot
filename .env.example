# =============================================================================
# Database (local dev uses host port 5433 to avoid clashing with any existing
# host Postgres on 5432)
# =============================================================================
DATABASE_URL=postgresql://lang:devpassword@localhost:5433/language_learning

# =============================================================================
# Auth
# Generate AUTH_SECRET with: openssl rand -base64 32
# =============================================================================
AUTH_SECRET=replace-with-32-byte-base64
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Encryption (for per-user LLM API keys at rest)
# Generate with: openssl rand -base64 32
# =============================================================================
APP_ENCRYPTION_KEY=replace-with-32-byte-base64

# =============================================================================
# Resend (transactional email — verification + password reset)
# For local dev without DNS setup you can use:
#   EMAIL_FROM="Language Learning Bot <onboarding@resend.dev>"
# but it will only deliver to the email you signed up to Resend with.
# Or set MOCK_EMAIL=1 below to log links to the console instead.
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Language Learning Bot <noreply@kebayorantechnologies.com>"

# Set to 1 to print verification/reset links to the server console
# instead of calling Resend. Useful before Resend is configured.
MOCK_EMAIL=

# =============================================================================
# App
# =============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
# In production: APP_URL=https://kebayorantechnologies.com/language-learning

# =============================================================================
# Base path (sub-path deployment)
# Leave empty in dev (app runs at the root). In production the app is served
# under /language-learning, so set all three. NEXT_PUBLIC_BASE_PATH is read by
# next.config.ts and inlined into the client bundle; WEB_BASEPATH and
# GCP_DEPLOYMENT are also passed as Docker build args (see Dockerfile and
# DEPLOYMENT.md). Remember NEXTAUTH_URL/APP_URL must include the sub-path too.
# =============================================================================
NEXT_PUBLIC_BASE_PATH=
# Production:
# NEXT_PUBLIC_BASE_PATH=/language-learning
# WEB_BASEPATH=/language-learning
# GCP_DEPLOYMENT=true

# =============================================================================
# LLM provider keys (OPTIONAL — only used as a dev fallback)
# Production uses per-user encrypted keys stored in user_settings.
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# Storage
# Dev: STORAGE_DRIVER=local writes files to LOCAL_STORAGE_DIR.
# Prod: STORAGE_DRIVER=gcs uses Google Cloud Storage; set GCS_BUCKET and
# GOOGLE_APPLICATION_CREDENTIALS to a path to the service-account JSON.
# The production bucket uses uniform access with bucket-wide public read, so
# putPublic does not call makePublic() — the direct storage.googleapis.com URL
# resolves because the whole bucket is publicly readable.
# =============================================================================
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
# Production:
# STORAGE_DRIVER=gcs
# GCS_BUCKET=language-learning-bot
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs-credentials.json
