# =============================================================================
# Database (local dev uses host port 5433 to avoid clashing with any existing
# host Postgres on 5432)
# =============================================================================
DATABASE_URL=postgresql://lang:devpassword@localhost:5433/language_learning

# =============================================================================
# Auth
# Generate AUTH_SECRET with: openssl rand -base64 32
# =============================================================================
AUTH_SECRET=replace-with-32-byte-base64
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Encryption (for per-user LLM API keys at rest)
# Generate with: openssl rand -base64 32
# =============================================================================
APP_ENCRYPTION_KEY=replace-with-32-byte-base64

# =============================================================================
# Resend (transactional email — verification + password reset)
# For local dev without DNS setup you can use:
#   EMAIL_FROM="Language Learning Bot <onboarding@resend.dev>"
# but it will only deliver to the email you signed up to Resend with.
# Or set MOCK_EMAIL=1 below to log links to the console instead.
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Language Learning Bot <noreply@kebayorantechnologies.com>"

# Set to 1 to print verification/reset links to the server console
# instead of calling Resend. Useful before Resend is configured.
MOCK_EMAIL=

# =============================================================================
# App
# =============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
# In production: APP_URL=https://kebayorantechnologies.com/language-learning
# and NEXT_PUBLIC_BASE_PATH=/language-learning

# =============================================================================
# LLM provider keys (OPTIONAL — only used as a dev fallback)
# Production uses per-user encrypted keys stored in user_settings.
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
